# Copia este fichero a `.env` y ajusta los valores antes de `docker compose up -d`.

# ───────── Base de datos ─────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=cambia-esta-clave
POSTGRES_DB=incidencias_db

# ───────── Backend / seguridad ─────────
# Clave para firmar los JWT. EN PRODUCCIÓN: usa una cadena larga y aleatoria.
SECRET_KEY=cambia-esta-clave-secreta-muy-larga-y-aleatoria
# Orígenes permitidos (con el proxy de origen único basta con el del frontend).
ALLOWED_ORIGINS=http://localhost:8080

# ───────── Administrador inicial ─────────
# Si defines AMBOS, al arrancar se crea/promueve este admin automáticamente.
BOOTSTRAP_ADMIN_EMAIL=admin@urban-alert.local
BOOTSTRAP_ADMIN_PASSWORD=admin123

# ───────── Imágenes / publicación ─────────
IMAGE_REPO=naoufalcharafat/urban-alert
BACKEND_TAG=backend
FRONTEND_TAG=frontend

# Puerto web del frontend en el host.
WEB_PORT=8080
