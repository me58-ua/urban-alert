# Configuración del backend. Copia este fichero a `.env` y ajusta los valores.
# NO subir `.env` al repositorio (está en .gitignore).

# Base de datos. Por defecto apunta al contenedor del proyecto (urban-alert-db, :5433).
DATABASE_URL=postgresql+psycopg2://admin:adminpassword@localhost:5433/incidencias_db

# Seguridad / JWT. ¡CAMBIAR SECRET_KEY en producción!
SECRET_KEY=dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS: orígenes permitidos separados por comas. Vacío = orígenes de desarrollo por defecto.
ALLOWED_ORIGINS=

# Subida de imágenes: tamaño máximo en bytes (5 MB).
MAX_IMAGEN_BYTES=5242880
